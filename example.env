# ============================================================
# BRING THESE KEYS TO THE WORKSHOP
# You need these two API keys before we start.
# ============================================================

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Brave Search — get your key at https://brave.com/search/api/
BRAVE_API_KEY=your-brave-api-key-here

# ============================================================
# OPTIONAL — Custom Claw (Notebook 1)
# Set up during the Telegram section of custom_claw.ipynb
# ============================================================

# Create a bot via @BotFather on Telegram, then get your chat ID
CUSTOM_CLAW_TELEGRAM_BOT_TOKEN=
CUSTOM_CLAW_TELEGRAM_CHAT_ID=

# ============================================================
# OPTIONAL — OpenClaw (Notebook 2)
# Set up during openclaw.ipynb
# ============================================================

# Create a second bot via @BotFather (or reuse the same one)
OPENCLAW_TELEGRAM_BOT_TOKEN=

# Opik — observability for OpenClaw. Get a free key at https://www.comet.com/opik
OPIK_API_KEY=
# Your Comet username (e.g. john-smith) — find it at https://www.comet.com/account-settings
OPIK_WORKSPACE=
